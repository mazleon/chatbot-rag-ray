# Application
APP_NAME=life-insurance-agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# LLM Provider: "openai" or "openrouter"
LLM_PROVIDER=openrouter

# OpenAI (get key from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# OpenRouter (get key from https://openrouter.ai/keys)
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=minimax/minimax-m2.5:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small

# Vector Store
VECTORSTORE_PATH=./vectorstore
VECTORSTORE_TYPE=faiss

# Redis (optional - uses in-memory if not available)
REDIS_URL=redis://localhost:6379

# LangFuse Observability
LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=sk-lf-445d50d8-9943-4163-8929-d91a513868ed
LANGFUSE_PUBLIC_KEY=pk-lf-0d970e7a-0273-4517-ab39-73bde17d4fe8
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# RAG
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.7

# Session
SESSION_MAX_TURNS=10
SESSION_TIMEOUT=3600