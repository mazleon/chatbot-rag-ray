# =============================================================================
# Docker Environment Configuration
# =============================================================================
# Copy this file to .env and replace with your actual values
# Required: OPENROUTER_API_KEY

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=life-insurance-agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# LLM Provider: "openai" or "openrouter"
# -----------------------------------------------------------------------------
LLM_PROVIDER=openrouter

# -----------------------------------------------------------------------------
# OpenRouter (Recommended - free tier models available)
# Get API key from: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# -----------------------------------------------------------------------------
# OpenAI (Optional - use instead of OpenRouter)
# Get API key from: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Embeddings (for RAG)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# Vector Store
# -----------------------------------------------------------------------------
VECTORSTORE_PATH=./vectorstore
VECTORSTORE_TYPE=faiss

# -----------------------------------------------------------------------------
# RAG Configuration
# -----------------------------------------------------------------------------
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Redis (Optional - uses in-memory fallback if not available)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_DB=0

# -----------------------------------------------------------------------------
# LangFuse Observability (Optional)
# Get keys from: https://cloud.langfuse.com
# -----------------------------------------------------------------------------
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# -----------------------------------------------------------------------------
# Session Management
# -----------------------------------------------------------------------------
SESSION_MAX_TURNS=10
SESSION_TIMEOUT=3600
