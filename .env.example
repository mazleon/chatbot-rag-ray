# Application
APP_NAME=life-insurance-agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# CORS (comma-separated list or "*" for all)
CORS_ORIGINS=*

# LLM Provider: "openai" or "openrouter"
LLM_PROVIDER=openrouter

# OpenAI (leave empty if using OpenRouter)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# OpenRouter (free tier models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5-8b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Vector Store
VECTORSTORE_PATH=./vectorstore
VECTORSTORE_TYPE=faiss

# RAG Configuration
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.7

# Redis (optional - uses in-memory fallback if not available)
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# LangFuse Observability (optional - set enabled to true to activate)
# LANGFUSE_ENABLED=false
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Session Management
SESSION_MAX_TURNS=10
SESSION_TIMEOUT=3600